APP_NAME=TrioSense
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Kolkata
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ---------- database ----------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=triosense
DB_USERNAME=triosense
DB_PASSWORD=triosense

# ---------- cache & queue ----------
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0

# ---------- broadcasting (Laravel Reverb) ----------
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=triosense
REVERB_APP_KEY=trioseanse-local-key
REVERB_APP_SECRET=triosense-local-secret
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http

# ---------- MQTT ----------
TRIOSENSE_MQTT_HOST=127.0.0.1
TRIOSENSE_MQTT_PORT=1883
TRIOSENSE_MQTT_TLS=false
TRIOSENSE_MQTT_USERNAME=
TRIOSENSE_MQTT_PASSWORD=
TRIOSENSE_MQTT_CLIENT_ID=triosense-backend-local
TRIOSENSE_MQTT_TOPIC_PREFIX=triosense

# ---------- FIFO ----------
TRIOSENSE_FIFO_TICK_INTERVAL_MS=1000
TRIOSENSE_FIFO_FESTIVAL_TICK_INTERVAL_MS=500
TRIOSENSE_FIFO_DEFAULT_MODE=shadow

# ---------- MQTT publishing (Sprint 7+) ----------
TRIOSENSE_MQTT_PUBLISH_ENABLED=false

# ---------- PA system ----------
TRIOSENSE_PA_CONTROLLER_URL=
TRIOSENSE_PA_DEFAULT_AUDIO_PATH=/var/lib/triosense/pa/default.mp3
TRIOSENSE_PA_TTS_PROVIDER=stub

# ---------- FCM push (Sprint 8+) ----------
TRIOSENSE_FCM_SERVER_KEY=

# ---------- Cross-counter (Sprint 9+) ----------
TRIOSENSE_CROSS_COUNTER_BUFFER=50

# ---------- Observability (Sprint 10+) ----------
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ---------- mail ----------
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="ops@triosense.in"
MAIL_FROM_NAME="${APP_NAME}"

# ---------- sanctum ----------
SANCTUM_STATEFUL_DOMAINS=localhost:3000
SESSION_DOMAIN=localhost
