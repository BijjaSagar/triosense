{
    "name": "triounity/triosense-backend",
    "type": "project",
    "description": "TrioSense — Central FIFO engine and API. Built by Triounity Technologies for TTD.",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "ext-pdo": "*",
        "ext-redis": "*",
        "laravel/framework": "^11.0",
        "laravel/sanctum": "^4.0",
        "laravel/reverb": "^1.0",
        "laravel/tinker": "^2.9",
        "spatie/laravel-permission": "^6.0",
        "spatie/laravel-data": "^4.0",
        "php-mqtt/laravel-client": "^1.3",
        "predis/predis": "^2.2",
        "nesbot/carbon": "^3.0",
        "league/openapi-psr7-validator": "^0.22"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "phpstan/phpstan": "^1.11",
        "larastan/larastan": "^2.9",
        "laravel/pint": "^1.17",
        "fakerphp/faker": "^1.23",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.1",
        "spatie/laravel-ignition": "^2.8"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "test": "@php artisan test --parallel",
        "stan": "phpstan analyse --memory-limit=2G",
        "pint": "pint"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
