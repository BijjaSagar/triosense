# TrioSense Dashboard — environment template
# Next.js loads .env.local at dev time. Copy this file:
#
#   cp .env.example .env.local

NEXT_PUBLIC_APP_NAME="TrioSense"
NEXT_PUBLIC_API_BASE_URL=http://localhost:8001
NEXT_PUBLIC_REVERB_APP_KEY=trioseanse-local-key
NEXT_PUBLIC_REVERB_HOST=127.0.0.1
NEXT_PUBLIC_REVERB_PORT=8090
NEXT_PUBLIC_REVERB_SCHEME=http
NEXT_PUBLIC_EDGE_PREVIEW_URL=http://127.0.0.1:8766

# Cookie auth: dashboard sends X-TrioSense-Auth: cookie on login.
# Ensure backend SANCTUM_STATEFUL_DOMAINS includes this dev server host:port.
