# TrioSense Edge — environment template
# Copy to .env for local simulate/dev runs. Production Jetson uses YAML at /etc/triosense/edge.yaml.
#
#   cp .env.example .env
#   source .env   # optional — simulate.py reads these via os.environ

# ---------- Identity ----------
TRIOSENSE_EDGE_DEVICE_UID=edge-vsn-01
TRIOSENSE_TENANT_ID=1
TRIOSENSE_LOCATION_ID=1

# ---------- MQTT broker ----------
TRIOSENSE_MQTT_HOST=127.0.0.1
TRIOSENSE_MQTT_PORT=1883
TRIOSENSE_MQTT_TLS=false
TRIOSENSE_MQTT_TOPIC_PREFIX=triosense
TRIOSENSE_MQTT_CLIENT_ID=edge-vsn-01-sim

# TLS paths — required when TRIOSENSE_MQTT_TLS=true (production / staging)
TRIOSENSE_MQTT_TLS_CERT_PATH=
TRIOSENSE_MQTT_TLS_KEY_PATH=
TRIOSENSE_MQTT_TLS_CA_PATH=

# ---------- Backend config API (production edge boot) ----------
TRIOSENSE_API_BASE_URL=http://localhost:8000
TRIOSENSE_EDGE_API_KEY=

# ---------- Inference (production pipeline) ----------
TRIOSENSE_INFERENCE_FPS=15
TRIOSENSE_INFERENCE_CONFIDENCE_THRESHOLD=0.5
TRIOSENSE_HEARTBEAT_SECONDS=5
TRIOSENSE_BUFFER_DB_PATH=./var/buffer.sqlite

# ---------- YAML config path (production entrypoint) ----------
TRIOSENSE_EDGE_CONFIG_PATH=config/location_3.example.yaml

# ---------- Simulate defaults ----------
TRIOSENSE_SIMULATE_SCENARIO=normal
TRIOSENSE_SIMULATE_EVENTS_PER_SEC=1

# ---------- Logging ----------
TRIOSENSE_LOG_LEVEL=INFO

# ---------- MQTT command subscription (Sprint 7+) ----------
# CommandSubscriber listens on triosense/loc/{location_id}/command/{device_uid}
# automatically when running the production entrypoint (python -m triosense_edge).
# No extra env vars required — uses TRIOSENSE_MQTT_* and device identity above.
