# TrioSense Mobile — environment template
# Copy to .env and load via flutter_dotenv (Sprint 1+) or pass as --dart-define.
#
#   cp .env.example .env

# ---------- API ----------
TRIOSENSE_API_BASE_URL=http://localhost:8000
TRIOSENSE_API_TIMEOUT_MS=30000

# ---------- WebSocket (Laravel Reverb / Pusher protocol) ----------
TRIOSENSE_REVERB_APP_KEY=trioseanse-local-key
TRIOSENSE_REVERB_HOST=127.0.0.1
TRIOSENSE_REVERB_PORT=8080
TRIOSENSE_REVERB_SCHEME=http

# ---------- Firebase Cloud Messaging (push notifications) ----------
# Leave blank for local dev without push. Required for staging/prod builds.
TRIOSENSE_FCM_ENABLED=false
FIREBASE_PROJECT_ID=
FIREBASE_ANDROID_APP_ID=
FIREBASE_IOS_APP_ID=

# ---------- App ----------
TRIOSENSE_APP_NAME=TrioSense
TRIOSENSE_DEFAULT_TENANT_SLUG=ttd
TRIOSENSE_STALE_STATE_THRESHOLD_SECONDS=60

# ---------- Logging ----------
TRIOSENSE_LOG_LEVEL=debug
