# Overrides for triosense-serve (API on host :8001). Host apps/backend/.env uses 127.0.0.1;
# inside the compose network use service hostnames.
APP_URL=http://localhost:8001
DB_HOST=mysql
DB_PORT=3306
REDIS_HOST=redis
REDIS_PORT=6379
SESSION_DRIVER=file
SESSION_DOMAIN=localhost
CACHE_STORE=file
QUEUE_CONNECTION=redis
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,localhost:3001,127.0.0.1,127.0.0.1:3001
